{
    "initialization_pose": "soma/soma_zero_frame0.bvh",
    "num_initialization_frames": 10,
    "num_stabilization_frames": 5,
    "human_robot_scaler_config": "q1/soma_to_q1_scaler_config.json",
    "feet_stabilizer_config": "q1/q1_feet_stabilizer_config.json",
    "model_height": 1.70,
    
    "ik_iterations" : 24,
    "joint_limit_weight": 10.0,
    "smooth_joint_filter_weight": 5.5,
    "collision_weight" : 0.0,
    "enable_post_processing" : true,

    "smooth_joint_filter_objective_body_masks" : {
        "L_shoulder_pitch_link" : 0.1,
        "L_shoulder_roll_link"  : 1.0,
        "L_shoulder_yaw_link"   : 0.3,
        "R_shoulder_pitch_link": 0.1,
        "R_shoulder_roll_link" : 1.0,
        "R_shoulder_yaw_link"  : 0.3
    },

    "ik_map": {
        "Hips": {
            "t_body" : "pelvis_link",
            "r_body" : "pelvis_link",
            "t_weight" : 30.0,
            "r_weight" : 2.0
        },
        "Chest": {
            "t_body" : "torso_link",
            "r_body" : "torso_link",
            "t_weight" : 0.7,
            "r_weight" : 0.7
        },
        "LeftArm": {
            "t_body" : "L_shoulder_roll_link",
            "r_body" : "L_shoulder_roll_link",
            "t_weight" : 1.5,
            "r_weight" : 0.15
        },
        "LeftForeArm": {
            "t_body" : "L_elbow_link",
            "r_body" : "L_elbow_link",
            "t_weight" : 1.0,
            "r_weight" : 1.0
        },
        "LeftHand": {
            "t_body" : "L_wrist_pitch_link",
            "r_body" : "L_wrist_pitch_link",
            "t_weight" : 2.0,
            "r_weight" : 1.2
        },
        "RightArm": {
            "t_body" : "R_shoulder_roll_link",
            "r_body" : "R_shoulder_roll_link",
            "t_weight" : 1.5,
            "r_weight" : 0.15
        },
        "RightForeArm": {
            "t_body" : "R_elbow_link",
            "r_body" : "R_elbow_link",
            "t_weight" : 1.0,
            "r_weight" : 1.0
        },
        "RightHand": {
            "t_body" : "R_wrist_pitch_link",
            "r_body" : "R_wrist_pitch_link",
            "t_weight" : 2.0,
            "r_weight" : 1.2
        },
        "LeftLeg": {
            "t_body" : "L_hip_roll_link",
            "r_body" : "L_hip_roll_link",
            "t_weight" : 1.5,
            "r_weight" : 0.15
        },
        "LeftShin": {
            "t_body" : "L_knee_link",
            "r_body" : "L_knee_link",
            "t_weight" : 1.0,
            "r_weight" : 1.0
        },
        "LeftFoot": {
            "t_body" : "L_ankle_roll_link",
            "r_body" : "L_ankle_roll_link",
            "t_weight" : 30.0,
            "r_weight" : 2.0
        },
        "RightLeg": {
            "t_body" : "R_hip_roll_link",
            "r_body" : "R_hip_roll_link",
            "t_weight" : 1.5,
            "r_weight" : 0.15
        },
        "RightShin": {
            "t_body" : "R_knee_link",
            "r_body" : "R_knee_link",
            "t_weight" : 1.0,
            "r_weight" : 1.0
        },
        "RightFoot": {
            "t_body" : "R_ankle_roll_link",
            "r_body" : "R_ankle_roll_link",
            "t_weight" : 30.0,
            "r_weight" : 2.0
        }
    }
}
